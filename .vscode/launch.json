{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Momentum Full Local (Requires Docker)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/extension/dist/**/*.js"
      ],
      "preLaunchTask": "momentum: local dev prepare"
    },
    {
      "name": "Run Momentum Extension (No Backend)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/extension/dist/**/*.js"
      ],
      "preLaunchTask": "momentum: build extension"
    }
  ]
}
