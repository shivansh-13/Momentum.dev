{
  "name": "momentum-dev-extension",
  "displayName": "Momentum.dev",
  "description": "Privacy-first coding consistency tracker for developers.",
  "publisher": "momentum-dev",
  "version": "0.1.0",
  "private": false,
  "main": "dist/extension.js",
  "categories": ["Other"],
  "keywords": ["productivity", "developer", "streak", "focus", "coding"],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/momentum.dev"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:momentum.openDashboard",
    "onCommand:momentum.pair",
    "onCommand:momentum.startSession",
    "onCommand:momentum.pauseSession",
    "onCommand:momentum.endSession"
  ],
  "contributes": {
    "commands": [
      {
        "command": "momentum.openDashboard",
        "title": "Momentum: Open Dashboard"
      },
      {
        "command": "momentum.pair",
        "title": "Momentum: Pair Device"
      },
      {
        "command": "momentum.startSession",
        "title": "Momentum: Start Session"
      },
      {
        "command": "momentum.pauseSession",
        "title": "Momentum: Pause Session"
      },
      {
        "command": "momentum.endSession",
        "title": "Momentum: End Session"
      }
    ],
    "configuration": {
      "title": "Momentum",
      "properties": {
        "momentum.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:54321/functions/v1",
          "description": "Momentum API base URL"
        },
        "momentum.mode": {
          "type": "string",
          "enum": ["personal", "work"],
          "default": "personal"
        },
        "momentum.idleThresholdSeconds": {
          "type": "number",
          "default": 120
        },
        "momentum.heartbeatIntervalSeconds": {
          "type": "number",
          "default": 60
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "echo \"typecheck skipped\"",
    "lint": "echo \"lint extension\"",
    "test": "vitest run",
    "package:vsix": "npx @vscode/vsce package -o momentum-dev.vsix",
    "publish:marketplace": "npx @vscode/vsce publish"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.2"
  }
}
